{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.toss-trading/schemas/virtual-decision.schema.json",
  "title": "VirtualDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["packetId", "summary", "decisions"],
  "properties": {
    "packetId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "decisions": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "required": ["action"],
              "properties": {
                "action": {
                  "const": "VIRTUAL_HOLD"
                }
              }
            },
            "then": {
              "required": ["holdReasonCode"],
              "properties": {
                "budgetKrw": {
                  "const": 0
                }
              }
            }
          },
          {
            "if": {
              "required": ["action"],
              "properties": {
                "action": {
                  "const": "VIRTUAL_SELL"
                }
              }
            },
            "then": {
              "anyOf": [
                {
                  "properties": {
                    "budgetKrw": {
                      "exclusiveMinimum": 0
                    }
                  }
                },
                {
                  "required": ["sellQuantity"]
                },
                {
                  "required": ["sellRatio"]
                },
                {
                  "required": ["targetWeightPct"]
                },
                {
                  "required": ["sellAll"],
                  "properties": {
                    "sellAll": {
                      "const": true
                    }
                  }
                }
              ]
            }
          },
          {
            "if": {
              "anyOf": [
                {
                  "required": ["sellQuantity"]
                },
                {
                  "required": ["sellRatio"]
                },
                {
                  "required": ["targetWeightPct"]
                },
                {
                  "required": ["sellAll"],
                  "properties": {
                    "sellAll": {
                      "const": true
                    }
                  }
                }
              ]
            },
            "then": {
              "required": ["reduceOnly"],
              "properties": {
                "reduceOnly": {
                  "const": true
                }
              }
            }
          }
        ],
        "required": [
          "symbol",
          "market",
          "action",
          "confidence",
          "budgetKrw",
          "thesis",
          "riskFactors",
          "dataRefs",
          "expiresAt"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "minLength": 1
          },
          "market": {
            "type": "string",
            "enum": ["KR", "US"]
          },
          "action": {
            "type": "string",
            "enum": ["VIRTUAL_BUY", "VIRTUAL_SELL", "VIRTUAL_HOLD"]
          },
          "holdReasonCode": {
            "type": "string",
            "enum": [
              "INSUFFICIENT_EVIDENCE",
              "STALE_DATA",
              "CONTRADICTORY_SIGNALS",
              "POLICY_BLOCKED",
              "PORTFOLIO_CONFLICT",
              "NO_POSITION_TO_SELL",
              "NOT_IN_CANDIDATES",
              "LOW_LIQUIDITY"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "budgetKrw": {
            "type": "integer",
            "minimum": 0
          },
          "maxBudgetKrw": {
            "type": "integer",
            "minimum": 0
          },
          "sellQuantity": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "sellRatio": {
            "type": "number",
            "exclusiveMinimum": 0,
            "maximum": 1
          },
          "targetWeightPct": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "sellAll": {
            "type": "boolean"
          },
          "reduceOnly": {
            "type": "boolean"
          },
          "thesis": {
            "type": "string",
            "minLength": 1
          },
          "riskFactors": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "dataRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
