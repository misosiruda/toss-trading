{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.toss-trading/schemas/virtual-decision.schema.json",
  "title": "VirtualDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packetId",
    "packetHash",
    "promptVersion",
    "modelId",
    "schemaVersion",
    "policyVersion",
    "summary",
    "decisions"
  ],
  "properties": {
    "packetId": {
      "type": "string"
    },
    "packetHash": {
      "type": "string"
    },
    "promptVersion": {
      "type": "string"
    },
    "modelId": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "policyVersion": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "symbol",
              "market",
              "action",
              "holdReasonCode",
              "confidence",
              "budgetKrw",
              "thesis",
              "riskFactors",
              "dataRefs",
              "claimSupport",
              "expiresAt"
            ],
            "properties": {
              "symbol": {
                "type": "string"
              },
              "market": {
                "type": "string",
                "enum": ["KR", "US"]
              },
              "action": {
                "type": "string",
                "enum": ["VIRTUAL_HOLD"]
              },
              "holdReasonCode": {
                "type": "string",
                "enum": [
                  "INSUFFICIENT_EVIDENCE",
                  "STALE_DATA",
                  "CONTRADICTORY_SIGNALS",
                  "POLICY_BLOCKED",
                  "PORTFOLIO_CONFLICT",
                  "NO_POSITION_TO_SELL",
                  "NOT_IN_CANDIDATES",
                  "LOW_LIQUIDITY"
                ]
              },
              "confidence": {
                "type": "number"
              },
              "budgetKrw": {
                "type": "integer"
              },
              "thesis": {
                "type": "string"
              },
              "riskFactors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "dataRefs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "claimSupport": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["claim", "dataRefs"],
                  "properties": {
                    "claim": {
                      "type": "string"
                    },
                    "dataRefs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "expiresAt": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "symbol",
              "market",
              "action",
              "confidence",
              "budgetKrw",
              "thesis",
              "riskFactors",
              "dataRefs",
              "claimSupport",
              "expiresAt"
            ],
            "properties": {
              "symbol": {
                "type": "string"
              },
              "market": {
                "type": "string",
                "enum": ["KR", "US"]
              },
              "action": {
                "type": "string",
                "enum": ["VIRTUAL_BUY"]
              },
              "confidence": {
                "type": "number"
              },
              "budgetKrw": {
                "type": "integer"
              },
              "thesis": {
                "type": "string"
              },
              "riskFactors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "dataRefs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "claimSupport": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["claim", "dataRefs"],
                  "properties": {
                    "claim": {
                      "type": "string"
                    },
                    "dataRefs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "expiresAt": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "symbol",
              "market",
              "action",
              "confidence",
              "budgetKrw",
              "reduceOnly",
              "thesis",
              "riskFactors",
              "dataRefs",
              "claimSupport",
              "expiresAt"
            ],
            "properties": {
              "symbol": {
                "type": "string"
              },
              "market": {
                "type": "string",
                "enum": ["KR", "US"]
              },
              "action": {
                "type": "string",
                "enum": ["VIRTUAL_SELL"]
              },
              "confidence": {
                "type": "number"
              },
              "budgetKrw": {
                "type": "integer"
              },
              "reduceOnly": {
                "type": "boolean"
              },
              "thesis": {
                "type": "string"
              },
              "riskFactors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "dataRefs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "claimSupport": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["claim", "dataRefs"],
                  "properties": {
                    "claim": {
                      "type": "string"
                    },
                    "dataRefs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "expiresAt": {
                "type": "string"
              }
            }
          }
        ]
      }
    }
  }
}
