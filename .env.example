BROKER_PROVIDER=mock
TRADING_ENABLED=false
TOSSINVEST_CLI_ENABLED=false
TOSSINVEST_CLI_READ_ONLY=true
TOSSINVEST_CLI_PATH=tossctl
TOSSINVEST_CLI_ALLOWED_COMMANDS=market.index,market.ranking,market.signals,market.screener,market.hours,market.fx,quote.get,quote.batch,quote.chart,quote.trades,quote.orderbook,quote.limits,quote.warnings,quote.flows,quote.commission,push.listen
TOSSINVEST_CLI_BLOCK_MUTATIONS=true
AI_DECISION_PROVIDER=codex_cli
AI_DECISION_MODE=paper_only
AI_DECISION_ENABLED=false
CODEX_EXEC_PATH=codex
CODEX_EXEC_SANDBOX=read-only
CODEX_EXEC_TIMEOUT_SECONDS=300
CODEX_DECISION_MAX_RUNS_PER_DAY=3
CODEX_DECISION_MAX_SYMBOLS=20
CODEX_DECISION_ALLOW_WEB_SEARCH=false
PAPER_TRADING_ENABLED=true
VIRTUAL_INITIAL_CASH_KRW=1000000
MAX_ORDER_AMOUNT_KRW=100000
ALLOWED_MARKETS=KR,US
ALLOWED_SYMBOLS=005930,AAPL,MSFT,NVDA
REQUIRE_PREVIEW=true
PREVIEW_TTL_SECONDS=60
