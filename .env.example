TOSSINVEST_CLI_BLOCK_MUTATIONS=true
TOSS_OPEN_API_AUTH_ENABLED=false
TOSS_OPEN_API_BASE_URL=https://openapi.tossinvest.com
TOSS_OPEN_API_CLIENT_ID=
TOSS_OPEN_API_CLIENT_SECRET=
MARKET_SOURCE_MAX_AGE_SECONDS=900
MARKET_CANDIDATE_TTL_SECONDS=300
MARKET_PACKET_TTL_SECONDS=300
MARKET_PACKET_MAX_CANDIDATES=10
PAPER_MAX_NEW_POSITIONS=3
AI_DECISION_PROVIDER=codex_cli
AI_DECISION_MODE=paper_only
AI_DECISION_ENABLED=false
CODEX_EXEC_PATH=codex
CODEX_EXEC_SANDBOX=read-only
